# Supabase PostgreSQL (obtenha a URL no Project Settings > Database do Supabase)
DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# NextAuth (gere uma chave com: openssl rand -base64 32)
AUTH_SECRET="sua-chave-secreta-aqui"

# URL base da aplicação (para produção, coloque a URL da Vercel)
AUTH_URL="http://localhost:3000"
